							"path": [
								"records",
								"dashboard",
								"summary"
							]
						}
					}
				},
				{
					"name": "Categories Breakdown",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{TOKEN}}"
